{
  "compilerOptions": {
    "target": "es2024",
    "module": "esnext",
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "noImplicitAny": true,
    "sourceMap": true,
    "paths": {
      "@nodebody/ui": ["../ui/src/index.ts"]
    },
    "moduleResolution": "bundler",
    "resolveJsonModule": true
  },
  "include": ["src", "vite-env.d.ts"]
}
