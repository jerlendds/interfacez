{
  "compilerOptions": {
    "target": "es2024",
    "module": "esnext",
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "noImplicitAny": true,
    "sourceMap": true,
    "paths": {
      "@/*": ["./src/*"]
    },
    "moduleResolution": "bundler",
    "resolveJsonModule": true
  },
  "include": [
    "src",
    "vite-env.d.ts",
    "../desktop/src/components/statusbar.ts",
    "../desktop/src/components/toolbar.ts"
  ]
}
